<?xml version="1.0" encoding="utf-8"?>
<options>
<dftgwbse help="Compute electronic excitations using GW-BSE">
	<job_name default="system" help="Input file name without extension, also used for intermediate files">molecule_neutral_tda</job_name>
<dftpackage>
<spin>1</spin>
<name>xtp</name>
<charge>0</charge>
<!--functional>XC_GGA_X_PBE XC_GGA_C_PBE</functional-->
<functional>XC_HYB_GGA_XC_PBEH</functional>
<basisset>3-21G.xml</basisset>
<initial_guess>huckel</initial_guess>
<xtpdft>
<screening_eps>1e-9</screening_eps>
<fock_matrix_reset>5</fock_matrix_reset>
<convergence>
    <energy>1e-5</energy>
    <method>DIIS</method>
    <DIIS_start>0.002</DIIS_start>
    <ADIIS_start>0.8</ADIIS_start>
    <DIIS_length>20</DIIS_length>
    <levelshift>0.0</levelshift>
    <levelshift_end>0.2</levelshift_end>
    <max_iterations>100</max_iterations>
    <error>1e-6</error>
    <DIIS_maxout>false</DIIS_maxout>
    <mixing>0.7</mixing>
</convergence>
<integration_grid>medium</integration_grid>
</xtpdft>
</dftpackage>
	<tasks choices="[guess,input,dft,parse,gwbse,localize,dft_in_dft]" default="input,dft,parse,gwbse" help="task to compute">input,dft,parse,gwbse</tasks>
	<gwbse>
	  <tasks>gw,singlets</tasks>
	  <auxbasisset>aux-def2-svp</auxbasisset>
	  <gw>
	    <mode>G0W0</mode>
	    <sigma_integrator>exact</sigma_integrator>
	  </gw>
	  <bse>
	    <dyn_screen_max_iter choices="int+" default="0" help="maximum number of iterations for perturbative dynamical screening in BSE">5</dyn_screen_max_iter>
	    <useTDA>true</useTDA>
	  </bse>
	</gwbse>
</dftgwbse>
</options>

